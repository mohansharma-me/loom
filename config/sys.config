[
    {kernel, [
        {logger_level, info},
        {logger, [
            {handler, default, logger_std_h, #{
                config => #{type => standard_io},
                formatter => {logger_formatter, #{
                    template => [time, " [", level, "] ", msg, "\n"],
                    single_line => true
                }}
            }}
        ]}
    ]},
    {sasl, [
        {sasl_error_logger, false}
    ]}
].

{minimum_otp_vsn, "27"}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec
]}.

{deps, [
    {cowboy, "2.14.2"},
    {prometheus, "6.1.2"}
]}.

{relx, [
    {release, {loom, "0.1.0"}, [loom, sasl]},
    {dev_mode, true},
    {include_erts, false},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {sys_config, undefined},
            {sys_config_src, "config/sys.config.src"},
            {vm_args, undefined},
            {vm_args_src, "config/vm.args.src"}
        ]}
    ]},
    {test, [
        {erl_opts, [debug_info, warnings_as_errors, nowarn_missing_spec]},
        {deps, [
            {gun, "2.1.0"},
            {proper, "1.4.0"},
            {meck, "0.9.2"}
        ]},
        {cover_enabled, true},
        {cover_opts, [verbose]}
    ]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{dialyzer, [
    {warnings, [
        error_handling,
        %% ASSUMPTION: underspecs removed because generic validation helpers
        %% (with_fields, require) use broad specs (map(), binary()) that
        %% Dialyzer narrows — these are not real type safety issues.
        unmatched_returns
    ]},
    %% Include ranch in PLT so cowboy_req types (ranch:ref/0) resolve.
    {plt_extra_apps, [ranch]},
    %% Suppress ranch_proxy_header:proxy_info/0 unknown type warning from
    %% cowboy_req.erl — ranch_proxy_header is an optional Cowboy dependency
    %% that we don't use.
    {warnings_filter, [
        {cowboy_req, unknown_type}
    ]}
]}.

{shell, [{apps, [loom]}]}.

{minimum_otp_vsn, "27"}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec
]}.

{deps, [
    {cowboy, "2.14.2"},
    {prometheus, "6.1.2"}
]}.

{relx, [
    {release, {loom, "0.1.0"}, [loom, sasl]},
    {dev_mode, true},
    {include_erts, false},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {sys_config, undefined},
            {sys_config_src, "config/sys.config.src"},
            {vm_args, undefined},
            {vm_args_src, "config/vm.args.src"}
        ]}
    ]},
    {test, [
        {erl_opts, [debug_info, warnings_as_errors, nowarn_missing_spec]}
    ]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{dialyzer, [
    {warnings, [
        error_handling,
        %% ASSUMPTION: underspecs removed because generic validation helpers
        %% (with_fields, require) use broad specs (map(), binary()) that
        %% Dialyzer narrows — these are not real type safety issues.
        unmatched_returns
    ]}
]}.

{shell, [{apps, [loom]}]}.
